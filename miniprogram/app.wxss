page {
  background: #f3f6f8;
  color: #17212f;
  font-size: 28rpx;
}
.notice {
  margin: 16rpx 20rpx 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: #e8f3f4;
  color: #145c72;
  font-weight: 600;
}
.panel, .card {
  margin: 14rpx 20rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1rpx solid #dde5eb;
}
.title {
  font-size: 32rpx;
  font-weight: 800;
}
.muted {
  color: #667085;
  font-size: 24rpx;
}
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin: 14rpx 20rpx;
}
.kpi {
  min-height: 132rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 1rpx solid #dde5eb;
  border-left: 8rpx solid #b7c5ce;
}
.kpi text:first-child {
  display: block;
  color: #667085;
  font-size: 24rpx;
}
.kpi text:last-child {
  color: #667085;
  font-size: 22rpx;
}
.kpi text:nth-child(2) {
  display: block;
  margin-top: 6rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: #17212f;
}
.kpi.ok { border-left-color: #168455; }
.kpi.warn { border-left-color: #b65f14; background: #fffaf3; }
.kpi.danger { border-left-color: #bd2c2c; background: #fff6f6; }
.judgment {
  margin: 14rpx 20rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  color: #fff;
  background: #145c72;
}
.judgment.danger { background: #8f2424; }
.judgment.warn { background: #9a5416; }
.judgment.ok { background: #166a4c; }
.judgment-top, .judgment-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}
.judgment-top text:last-child {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.18);
}
.judgment-grid {
  margin: 18rpx 0 12rpx;
}
.judgment-grid view {
  display: grid;
  gap: 4rpx;
}
.judgment-grid text:first-child, .judgment-text {
  color: rgba(255,255,255,.8);
  font-size: 22rpx;
}
.judgment-grid text:last-child {
  font-size: 40rpx;
  font-weight: 800;
}
.section-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}
.compact {
  display: grid;
  gap: 10rpx;
}
.mini-row, .dept-row {
  padding: 14rpx;
  border-radius: 14rpx;
  background: #f8fbfd;
  border-left: 6rpx solid #c9d5dc;
}
.danger-left { border-left-color: #bd2c2c; }
.mini-row view, .dept-row view {
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
.mini-row text, .dept-row text {
  display: block;
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
}
.todo-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}
.todo-grid view {
  display: grid;
  justify-items: center;
  gap: 4rpx;
  padding: 12rpx 4rpx;
  border-radius: 12rpx;
  background: #f4f7f9;
}
.todo-grid text:first-child {
  color: #145c72;
  font-weight: 800;
  font-size: 34rpx;
}
.todo-grid text:last-child {
  color: #667085;
  font-size: 20rpx;
}
.tag {
  display: inline-block;
  margin-right: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eef2f6;
  color: #475467;
  font-size: 22rpx;
}
.tag-line {
  white-space: nowrap;
}
.task-card {
  display: grid;
  gap: 10rpx;
}
.task-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.progress-row {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 12rpx;
}
.progress {
  height: 12rpx;
  border-radius: 999rpx;
  background: #e8eef3;
  overflow: hidden;
}
.progress view {
  height: 100%;
  background: #145c72;
}
.progress-row text {
  color: #145c72;
  font-weight: 800;
  font-size: 24rpx;
}
.button-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.primary, .secondary {
  border-radius: 999rpx;
  font-weight: 700;
}
.primary {
  background: #145c72;
  color: #fff;
}
.secondary {
  background: #e8f3f4;
  color: #145c72;
}
